rm(list = ls())   # Clearing the memory
# Setting a working directory
setwd("C:/projects/afrm_iim_kashipur/Course Material/afrmsession10materialtouploadonlms")
# Importing data from reliance.csv file
price   <- read.csv("reliance.csv", header = TRUE)
# Separating the price series from second column
nifty_p <- price[, 2]
n       <- length(nifty_p)
# Estimate simple return
nifty   <- diff(nifty_p) / lag(nifty_p)
nifty   <- nifty[1:(n - 1)]
library(rugarch)
# ---------------- Helper: Gaussian GARCH(1,1) log-likelihood ----------------
garch11_gaussian_ll <- function(par, y) {
omega  <- par["omega"]
alpha1 <- par["alpha1"]
beta1  <- par["beta1"]
T <- length(y)
h <- numeric(T)
# unconditional variance as starting variance
h[1] <- omega / (1 - alpha1 - beta1)
for (t in 2:T) {
h[t] <- omega + alpha1 * y[t - 1]^2 + beta1 * h[t - 1]
}
# Gaussian log-likelihood
ll <- -0.5 * sum(log(2 * pi) + log(h) + (y^2) / h)
return(ll)
}
# Specify a GARCH Model: normal distribution
spec1 <- ugarchspec(
variance.model = list(model = "sGARCH", garchOrder = c(1, 1)),
mean.model     = list(armaOrder = c(0, 0), include.mean = FALSE),
distribution.model = "norm"
)
# Fit a GARCH model
garch_fit_1 <- ugarchfit(spec = spec1, data = nifty)
garch_fit_1
garch_fit_1
# Extract sigma and save
sigma <- garch_fit_1@fit$sigma
write.csv(sigma, file = "vol_estimates_GARCH_reliance.csv")
# ---- Initial and final log-likelihood for normal GARCH(1,1) ----
# Initial parameters used by optimizer
ipars    <- garch_fit_1@fit$ipars
init_par <- ipars[c("omega", "alpha1", "beta1"), "init"]
View(garch_fit_1)
